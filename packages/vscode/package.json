{
  "name": "spek-vscode",
  "displayName": "spek — OpenSpec Viewer",
  "description": "Browse OpenSpec specs and changes directly in VS Code",
  "version": "0.7.8",
  "publisher": "kewang",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/kewang/spek#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kewang/spek.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/kewang/spek/issues"
  },
  "keywords": [
    "openspec",
    "spec",
    "bdd",
    "documentation",
    "viewer"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:openspec/config.yaml",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spek.open",
        "title": "Open spek",
        "category": "spek"
      },
      {
        "command": "spek.search",
        "title": "Search OpenSpec",
        "category": "spek"
      },
      {
        "command": "spek.openDashboard",
        "title": "Open Dashboard",
        "category": "spek",
        "icon": "$(link-external)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spek-sidebar",
          "title": "spek",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "spek-sidebar": [
        {
          "id": "spek.specsView",
          "name": "Specs",
          "when": "spek.hasOpenSpec"
        },
        {
          "id": "spek.changesView",
          "name": "Changes",
          "when": "spek.hasOpenSpec"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "spek.openDashboard",
          "when": "view == spek.specsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "@vscode/vsce": "^3.0.0",
    "@spek/core": "*",
    "fuse.js": "^7.0.0"
  }
}
