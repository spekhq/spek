{
  "name": "@spekjs/core",
  "version": "1.1.0",
  "description": "Framework-agnostic engine for reading OpenSpec repositories — scanner, tasks parser, worktree aggregation and shared types.",
  "keywords": [
    "openspec",
    "spec-driven-development",
    "sdd",
    "spec",
    "parser"
  ],
  "license": "MIT",
  "author": "Kewang",
  "homepage": "https://github.com/spekhq/spek#readme",
  "bugs": "https://github.com/spekhq/spek/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spekhq/spek.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./headings": {
      "import": "./dist/headings.js",
      "types": "./dist/headings.d.ts"
    },
    "./artifact-order": {
      "import": "./dist/artifact-order.js",
      "types": "./dist/artifact-order.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
