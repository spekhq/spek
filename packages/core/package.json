{
  "name": "@spek/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./headings": {
      "import": "./dist/headings.js",
      "types": "./dist/headings.d.ts"
    },
    "./artifact-order": {
      "import": "./dist/artifact-order.js",
      "types": "./dist/artifact-order.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
